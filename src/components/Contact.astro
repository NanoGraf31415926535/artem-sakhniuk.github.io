---
import type { Locale } from "@/i18n";
import { t } from "@/i18n";
import { profile } from "@/data/profile";
import { Icon } from "astro-icon/components";

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<section id="contact" class="py-24 bg-[var(--color-bg-secondary)]">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-[var(--color-text-primary)] text-4xl sm:text-5xl font-bold text-center mb-16 fade-in-section">
      {t("contact.title", locale)}
    </h2>

    <div class="grid md:grid-cols-[300px_1fr] gap-12 fade-in-section">
      <!-- Contact Links -->
      <div class="space-y-4">
        <a
          href={`mailto:${profile.email}`}
          class="flex items-center gap-3 p-4 rounded-xl transition-all duration-200 group"
          class:list={[
            "bg-[var(--color-card-bg)] hover:shadow-md hover:shadow-[var(--color-card-shadow)]",
          ]}
        >
          <Icon
            name="lucide:mail"
            class="w-5 h-5 text-[var(--color-text-secondary)]"
          />
          <span class="text-[var(--color-text-secondary)] group-hover:text-[var(--color-text-primary)] transition-colors">
            {t("contact.emailMe", locale)}
          </span>
        </a>

        <a
          href={profile.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 p-4 rounded-xl transition-all duration-200 group"
          class:list={[
            "bg-[var(--color-card-bg)] hover:shadow-md hover:shadow-[var(--color-card-shadow)]",
          ]}
        >
          <Icon
            name="lucide:linkedin"
            class="w-5 h-5 text-[var(--color-text-secondary)]"
          />
          <span class="text-[var(--color-text-secondary)] group-hover:text-[var(--color-text-primary)] transition-colors">
            {t("contact.linkedin", locale)}
          </span>
        </a>

        <a
          href={profile.github}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 p-4 rounded-xl transition-all duration-200 group"
          class:list={[
            "bg-[var(--color-card-bg)] hover:shadow-md hover:shadow-[var(--color-card-shadow)]",
          ]}
        >
          <Icon
            name="lucide:github"
            class="w-5 h-5 text-[var(--color-text-secondary)]"
          />
          <span class="text-[var(--color-text-secondary)] group-hover:text-[var(--color-text-primary)] transition-colors">
            {t("contact.github", locale)}
          </span>
        </a>

        <a
          href={`tel:${profile.phone}`}
          class="flex items-center gap-3 p-4 rounded-xl transition-all duration-200 group"
          class:list={[
            "bg-[var(--color-card-bg)] hover:shadow-md hover:shadow-[var(--color-card-shadow)]",
          ]}
        >
          <Icon
            name="lucide:phone"
            class="w-5 h-5 text-[var(--color-text-secondary)]"
          />
          <span class="text-[var(--color-text-secondary)] group-hover:text-[var(--color-text-primary)] transition-colors">
            {t("contact.callMe", locale)}
          </span>
        </a>
      </div>

      <!-- Contact Form -->
      <form
        id="contact-form"
        action="https://formspree.io/f/movlgnaa"
        method="POST"
        class="space-y-5"
        class:list={["bg-[var(--color-card-bg)] p-8 rounded-xl shadow-lg shadow-[var(--color-card-shadow)]"]}
      >
        <div>
          <label for="name" class="block text-sm font-medium mb-2 text-[var(--color-text-primary)]">
            {t("contact.yourName", locale)}
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full px-4 py-3 rounded-lg border transition-colors duration-200 outline-none"
            class:list={[
              "bg-[var(--color-bg-main)] border-[var(--color-border-light)] text-[var(--color-text-primary)] focus:border-[var(--color-text-primary)] focus:ring-2 focus:ring-[var(--color-text-primary)]/20",
            ]}
          />
        </div>

        <div>
          <label for="email" class="block text-sm font-medium mb-2 text-[var(--color-text-primary)]">
            {t("contact.yourEmail", locale)}
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full px-4 py-3 rounded-lg border transition-colors duration-200 outline-none"
            class:list={[
              "bg-[var(--color-bg-main)] border-[var(--color-border-light)] text-[var(--color-text-primary)] focus:border-[var(--color-text-primary)] focus:ring-2 focus:ring-[var(--color-text-primary)]/20",
            ]}
          />
        </div>

        <div>
          <label for="subject" class="block text-sm font-medium mb-2 text-[var(--color-text-primary)]">
            {t("contact.subject", locale)}
          </label>
          <input
            type="text"
            id="subject"
            name="subject"
            required
            class="w-full px-4 py-3 rounded-lg border transition-colors duration-200 outline-none"
            class:list={[
              "bg-[var(--color-bg-main)] border-[var(--color-border-light)] text-[var(--color-text-primary)] focus:border-[var(--color-text-primary)] focus:ring-2 focus:ring-[var(--color-text-primary)]/20",
            ]}
          />
        </div>

        <div>
          <label for="message" class="block text-sm font-medium mb-2 text-[var(--color-text-primary)]">
            {t("contact.message", locale)}
          </label>
          <textarea
            id="message"
            name="message"
            required
            rows={5}
            class="w-full px-4 py-3 rounded-lg border transition-colors duration-200 outline-none resize-vertical"
            class:list={[
              "bg-[var(--color-bg-main)] border-[var(--color-border-light)] text-[var(--color-text-primary)] focus:border-[var(--color-text-primary)] focus:ring-2 focus:ring-[var(--color-text-primary)]/20",
            ]}
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full py-3 rounded-full font-semibold transition-all duration-300 gradient-bg hover:scale-[1.02] hover:shadow-lg active:scale-95"
        >
          {t("contact.sendMessage", locale)}
        </button>
      </form>
    </div>
  </div>
</section>
