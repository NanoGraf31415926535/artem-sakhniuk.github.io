---
import { Icon } from "astro-icon/components";
import { faq } from "@/data/faq";
---

<style>
  /* ── Terminal skin — uses only site B&W design tokens ─────── */
  @keyframes scanlines {
    0%   { transform: translateY(0); }
    100% { transform: translateY(4px); }
  }
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(4px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* FAB — square, bordered, monospace glyph */
  #chat-fab {
    border-radius: 0 !important;
    background: var(--color-bg-main) !important;
    border: 1px solid var(--color-text-primary);
    box-shadow: 3px 3px 0 var(--color-text-primary);
    transition: box-shadow 0.15s, transform 0.15s;
  }
  #chat-fab:hover {
    box-shadow: 5px 5px 0 var(--color-text-primary);
    transform: translate(-1px, -1px);
  }
  #chat-fab:active {
    box-shadow: 1px 1px 0 var(--color-text-primary);
    transform: translate(1px, 1px);
  }

  /* Window */
  .term-window {
    border-radius: 0 !important;
    background: var(--color-bg-main);
    border: 1px solid var(--color-text-primary);
    box-shadow: 6px 6px 0 var(--color-text-primary);
    font-family: 'JetBrains Mono', 'Fira Code', ui-monospace, 'Courier New', monospace;
    position: relative;
    overflow: hidden;
  }

  /* Scanlines — very subtle, uses text color at low opacity */
  .term-window::after {
    content: '';
    pointer-events: none;
    position: absolute;
    top: -4px;
    left: 0;
    right: 0;
    bottom: 0;
    height: calc(100% + 8px);
    z-index: 99;
    background: repeating-linear-gradient(
      to bottom,
      rgba(128,128,128,0.03) 0px,
      rgba(128,128,128,0.03) 1px,
      transparent 1px,
      transparent 4px
    );
    will-change: transform;
    animation: scanlines 0.4s linear infinite;
  }
  @media (prefers-reduced-motion: reduce) {
    .term-window::after { animation: none; }
  }

  /* Title bar */
  .term-titlebar {
    background: var(--color-text-primary);
    color: var(--color-bg-main);
    padding: 7px 12px;
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .term-dots {
    display: flex;
    gap: 5px;
  }
  .term-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--color-bg-main);
    opacity: 0.3;
  }
  .term-dot.active { opacity: 1; }
  .term-title-text {
    flex: 1;
    text-align: center;
    opacity: 0.85;
  }
  .term-close {
    background: none;
    border: none;
    color: var(--color-bg-main);
    cursor: pointer;
    font-size: 14px;
    line-height: 1;
    opacity: 0.6;
    padding: 0 2px;
    font-family: inherit;
    transition: opacity 0.15s;
  }
  .term-close:hover { opacity: 1; }

  /* Shell info line */
  .term-header {
    border-bottom: 1px solid var(--color-border-light);
    padding: 9px 14px;
    background: var(--color-bg-secondary, var(--color-bg-main));
  }
  .term-header-line {
    font-size: 11px;
    color: var(--color-text-tertiary);
    letter-spacing: 0.04em;
  }
  .term-header-line .hl-primary { color: var(--color-text-primary); }
  .term-header-line .hl-dim     { color: var(--color-text-tertiary); }

  /* Prompt chips */
  .term-prompts {
    border-bottom: 1px solid var(--color-border-light);
    padding: 8px 12px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    background: var(--color-bg-tertiary, var(--color-bg-main));
    display: flex;
    gap: 6px;
    flex-wrap: nowrap;
  }
  .premade-btn {
    background: transparent;
    border: 1px solid var(--color-border-light);
    color: var(--color-text-secondary);
    font-family: inherit;
    font-size: 10px;
    letter-spacing: 0.07em;
    padding: 3px 10px;
    white-space: nowrap;
    cursor: pointer;
    text-transform: uppercase;
    border-radius: 0;
    transition: background 0.12s, color 0.12s, border-color 0.12s;
    flex-shrink: 0;
  }
  .premade-btn:hover {
    background: var(--color-text-primary);
    color: var(--color-bg-main);
    border-color: var(--color-text-primary);
  }

  /* Chat history */
  #chat-history {
    background: var(--color-bg-main);
    padding: 12px 14px;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    flex: 1;
    min-height: 280px;
    scroll-behavior: smooth;
  }

  /* Messages */
  .term-msg {
    margin-bottom: 14px;
    animation: fadeInUp 0.15s ease;
  }
  .term-prompt-label {
    font-size: 10px;
    letter-spacing: 0.06em;
    margin-bottom: 2px;
    text-transform: lowercase;
  }
  .term-msg-user .term-prompt-label { color: var(--color-text-tertiary); }
  .term-msg-user .term-bubble {
    color: var(--color-text-primary);
    font-size: 13px;
    line-height: 1.55;
    word-break: break-word;
  }
  .term-msg-ai .term-prompt-label {
    color: var(--color-text-tertiary);
  }
  .term-msg-ai .term-bubble {
    color: var(--color-text-secondary);
    font-size: 13px;
    line-height: 1.6;
    word-break: break-word;
  }

  /* Loading */
  #chat-loading .term-bubble { color: var(--color-text-tertiary); }
  .cursor-blink {
    display: inline-block;
    width: 7px;
    height: 13px;
    background: var(--color-text-primary);
    vertical-align: middle;
    margin-left: 3px;
    animation: blink 0.75s step-end infinite;
  }

  /* Input */
  .term-input-row {
    background: var(--color-bg-tertiary, var(--color-bg-main));
    border-top: 1px solid var(--color-text-primary);
    padding: 9px 14px;
    display: flex;
    align-items: flex-end;
    gap: 8px;
  }
  .term-prompt-glyph {
    color: var(--color-text-primary);
    font-size: 15px;
    padding-bottom: 1px;
    flex-shrink: 0;
    user-select: none;
  }
  #chat-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    resize: none;
    color: var(--color-text-primary);
    font-family: inherit;
    font-size: 13px;
    line-height: 1.5;
    max-height: 88px;
    caret-color: var(--color-text-primary);
  }
  #chat-input::placeholder {
    color: var(--color-text-tertiary);
  }
  #chat-send-btn {
    background: transparent;
    border: 1px solid var(--color-border-light);
    color: var(--color-text-secondary);
    width: 30px;
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    flex-shrink: 0;
    border-radius: 0;
    font-family: inherit;
    font-size: 14px;
    transition: background 0.12s, color 0.12s, border-color 0.12s;
  }
  #chat-send-btn:hover:not(:disabled) {
    background: var(--color-text-primary);
    color: var(--color-bg-main);
    border-color: var(--color-text-primary);
  }
  #chat-send-btn:disabled { opacity: 0.25; cursor: not-allowed; }

  /* Status bar */
  .term-statusbar {
    border-top: 1px solid var(--color-border-light);
    background: var(--color-bg-secondary, var(--color-bg-main));
    padding: 4px 14px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 10px;
    color: var(--color-text-tertiary);
    letter-spacing: 0.05em;
    gap: 8px;
  }
  #chat-status { color: var(--color-text-secondary); }

  /* iOS Safari zooms the whole page on focus if an input's font-size
     is under 16px — this caused the "jump"/jank feeling on phones. */
  @media (max-width: 640px) {
    .term-window {
      height: 100dvh;
      border: none;
      box-shadow: none;
    }
    .term-statusbar {
      display: none;
    }
    #chat-input {
      font-size: 16px;
    }
  }
</style>

<!-- FAB -->
<button
  id="chat-fab"
  class="fixed bottom-20 left-6 z-40 w-14 h-14 cursor-pointer flex items-center justify-center"
  aria-label="Open AI Chat"
>
  <span style="font-family:'JetBrains Mono',monospace;font-size:18px;color:var(--color-text-primary);line-height:1;">&gt;_</span>
</button>

<!-- Modal -->
<div id="ai-chat-modal" class="fixed inset-0 z-50 flex items-end sm:items-center justify-center hidden">
  <div id="chat-overlay" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>

  <div class="term-window relative w-full sm:max-w-lg sm:mx-4 sm:max-h-[92vh] flex flex-col">

    <!-- Title bar (inverted) -->
    <div class="term-titlebar">
      <div class="term-dots">
        <div class="term-dot"></div>
        <div class="term-dot"></div>
        <div class="term-dot active"></div>
      </div>
      <span class="term-title-text">artem-ai — bash — 80×24</span>
      <button id="chat-close-btn" class="term-close" aria-label="Close">✕</button>
    </div>

    <!-- Shell line -->
    <div class="term-header">
      <div class="term-header-line">
        <span class="hl-primary">artem@portfolio</span><span class="hl-dim">:~$</span>
        &nbsp;./ask-artem <span class="hl-dim">--model gpt-4o --interactive</span>
      </div>
      <div class="term-header-line" style="margin-top:3px;">
        <span class="hl-dim">● connected &nbsp;|&nbsp; context loaded &nbsp;|&nbsp; ready</span>
      </div>
    </div>

    <!-- Quick-query chips -->
    <div class="term-prompts">
      {faq.map((item) => (
        <button class="premade-btn">&gt; {item.question}</button>
      ))}
    </div>

    <!-- Chat history -->
    <div id="chat-history"></div>

    <!-- Input row -->
    <div class="term-input-row">
      <span class="term-prompt-glyph">❯</span>
      <textarea
        id="chat-input"
        rows={1}
        placeholder="type a query and press enter..."
      ></textarea>
      <button id="chat-send-btn" disabled aria-label="Send">↵</button>
    </div>

    <!-- Status bar -->
    <div class="term-statusbar">
      <span id="chat-status" class="hidden"></span>
      <span style="margin-left:auto;">esc · close &nbsp;|&nbsp; enter · send &nbsp;|&nbsp; shift+enter · newline</span>
    </div>
  </div>
</div>

<script>
  import { faq } from "@/data/faq";

  const modal     = document.getElementById("ai-chat-modal")!;
  const overlay   = document.getElementById("chat-overlay")!;
  const fab       = document.getElementById("chat-fab")!;
  const closeBtn  = document.getElementById("chat-close-btn")!;
  const history   = document.getElementById("chat-history")!;
  const input     = document.getElementById("chat-input") as HTMLTextAreaElement;
  const sendBtn   = document.getElementById("chat-send-btn") as HTMLButtonElement;
  const status    = document.getElementById("chat-status")!;
  const premadeBtns = document.querySelectorAll(".premade-btn");

  let conversation: { role: "user" | "assistant"; content: string }[] = [];
  let useFallback = false;

  const portfolioContext = `
**Role:** You are Artem Sakhniuk's personal AI assistant. Provide concise, accurate, friendly information about Artem's skills, experience, and personal life.

**Profile:**
Artem Sakhniuk is a UK-based Full-Stack Web Developer with a background in Bioinformatics. He holds full rights to work in the UK. He holds a Bachelor of Biology with a specialization in Bioinformatics from Taras Shevchenko National University (3.9 GPA).

**Personal:**
Artem is in a loving relationship with his wonderful girlfriend Victoria, whom he adores.

**Core Expertise:**
* **Full-Stack Development:** React, Vue.js, Angular, Next.js (frontend); Node.js, Django, Flask, FastAPI, Laravel (backend).
* **Languages:** Python (strongest), JavaScript/ES6+, TypeScript, PHP, C++, C#, Java.
* **Database:** PostgreSQL, SQL, SQLAlchemy.
* **Data Science:** NumPy, Pandas, Matplotlib, Machine Learning, Bioinformatics.
* **DevOps:** Git, Docker, CI/CD, Pytest, Agile.

**Professional Experience:**
1. **Ruth Miskin Training (Oct 2025 - Present):** Full Stack Software Developer. Building educational platform with Flask + React. Increased course completion rates by 25%.
2. **The Code Registry (Jun 2025 - Oct 2026):** Full Stack Web Developer. Architected Django + Angular platform supporting 10K+ users. Implemented CI/CD reducing deployment time by 50%.
3. **Freelance (Aug 2025 - Sep 2025):** Full Stack AI Developer. Built AI-driven web app with ML personalization for client Lukas Emanuel Holz.
4. **Goethe University (Jun 2024 - Jun 2025):** Web Developer Full-Stack. Led AI-Powered Interviewer System using Python + OpenAI API. Achieved 90% client satisfaction.
5. **Capstone (Oct 2022 - Aug 2023):** Python Developer. Built genomic data visualization tool with Flask.

**Contact:**
- Email: artemsakhnyuk33@gmail.com
- Phone: +447846481665
- LinkedIn: https://www.linkedin.com/in/artem-sakhniuk-0851b4231/
- GitHub: https://github.com/NanoGraf31415926535

**Format:** Use conversational, narrative-driven paragraphs. Do not use bullet lists in responses about skills or summaries.

**Constraint:** Only answer based on the provided information. Do not fabricate.
`;

  function addMessage(role: "user" | "assistant", text: string) {
    const div = document.createElement("div");
    div.className = `term-msg term-msg-${role === "user" ? "user" : "ai"}`;
    const label = role === "user" ? "visitor@portfolio:~$" : "artem-ai@portfolio:~#";
    div.innerHTML = `
      <div class="term-prompt-label">${label}</div>
      <div class="term-bubble">${text}</div>
    `;
    history.appendChild(div);
    history.scrollTop = history.scrollHeight;
  }

  // Typewriter: streams text into a new AI bubble char by char
  function typeMessage(text: string): Promise<void> {
    return new Promise((resolve) => {
      const div = document.createElement("div");
      div.className = "term-msg term-msg-ai";
      const bubble = document.createElement("div");
      bubble.className = "term-bubble";
      const textNode = document.createTextNode("");
      const cursor = document.createElement("span");
      cursor.className = "cursor-blink";
      div.innerHTML = `<div class="term-prompt-label">artem-ai@portfolio:~#</div>`;
      div.appendChild(bubble);
      bubble.appendChild(textNode);
      bubble.appendChild(cursor);
      history.appendChild(div);

      const chars = Array.from(text); // handles unicode correctly
      let i = 0;
      let scrollQueued = false;

      // Batch scroll/layout work to once per animation frame instead of
      // once per character, and only auto-scroll if the reader is
      // already near the bottom (don't yank them down if they scrolled up).
      function queueScroll() {
        if (scrollQueued) return;
        scrollQueued = true;
        requestAnimationFrame(() => {
          const nearBottom =
            history.scrollHeight - history.scrollTop - history.clientHeight < 60;
          if (nearBottom) history.scrollTop = history.scrollHeight;
          scrollQueued = false;
        });
      }

      // Variable speed: faster for spaces/common chars, slight pause at punctuation
      function nextChar() {
        if (i >= chars.length) {
          cursor.remove();
          resolve();
          return;
        }
        const ch = chars[i++];
        textNode.textContent += ch;
        queueScroll();

        let delay = 18; // base ms per char
        if (ch === "." || ch === "!" || ch === "?") delay = 90;
        else if (ch === ",") delay = 45;
        else if (ch === " ") delay = 10;
        // Small random jitter for organic feel
        delay += Math.random() * 12;

        setTimeout(nextChar, delay);
      }

      nextChar();
    });
  }

  function addLoading() {
    const div = document.createElement("div");
    div.id = "chat-loading";
    div.className = "term-msg term-msg-ai";
    div.innerHTML = `
      <div class="term-prompt-label">artem-ai@portfolio:~#</div>
      <div class="term-bubble">processing<span class="cursor-blink"></span></div>
    `;
    history.appendChild(div);
    history.scrollTop = history.scrollHeight;
  }

  function removeLoading() {
    document.getElementById("chat-loading")?.remove();
  }

  function getFaqAnswer(query: string): string | null {
    const q = query.toLowerCase();
    for (const item of faq) {
      const keywords = item.question.toLowerCase();
      const qWords = q.split(/\s+/);
      const matchCount = qWords.filter((w) => keywords.includes(w) && w.length > 3).length;
      if (matchCount >= 2) return item.answer;
    }
    return null;
  }

  async function sendMessage(message: string) {
    if (!message.trim()) return;
    addMessage("user", message);
    conversation.push({ role: "user", content: message });
    input.value = "";
    input.style.height = "auto";
    sendBtn.disabled = true;
    addLoading();

    try {
      if (useFallback) {
        const answer = getFaqAnswer(message) || "No match found. Try querying about skills, experience, or projects.";
        await new Promise((r) => setTimeout(r, 400));
        removeLoading();
        await typeMessage(answer);
        conversation.push({ role: "assistant", content: answer });
      } else {
        const messages = [
          { role: "system", content: portfolioContext },
          ...conversation,
          { role: "user", content: message },
        ];

        const res = await fetch("https://artem-ai-proxy.artemsakhnyuk33.workers.dev", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ messages }),
        });

        const data = await res.json();
        removeLoading();

        if (data.text) {
          await typeMessage(data.text);
          conversation.push({ role: "assistant", content: data.text });
        } else {
          throw new Error(data.error || "Empty response");
        }
      }
    } catch {
      removeLoading();
      if (!useFallback) {
        useFallback = true;
        status.classList.remove("hidden");
        status.textContent = "⚠ ai offline — faq fallback active";
        const answer = getFaqAnswer(message) || "No match in FAQ. Try asking about Artem's skills, projects, or experience.";
        await typeMessage(answer);
        conversation.push({ role: "assistant", content: answer });
      } else {
        await typeMessage("ERR: connection timeout. Retry in a moment.");
      }
    }

    sendBtn.disabled = false;
    input.focus();
  }

  const openModal = () => {
    modal.classList.remove("hidden");
    modal.classList.add("flex");
    input.focus();
    if (conversation.length === 0) {
      const greeting = "System ready. I'm Artem's AI assistant — query me about his skills, projects, or background.";
      typeMessage(greeting);
      conversation.push({ role: "assistant", content: greeting });
    }
  };

  fab.addEventListener("click", openModal);
  document.getElementById("open-ai-chat-btn")?.addEventListener("click", openModal);

  const closeModal = () => {
    modal.classList.add("hidden");
    modal.classList.remove("flex");
  };

  overlay.addEventListener("click", closeModal);
  closeBtn.addEventListener("click", closeModal);
  sendBtn.addEventListener("click", () => sendMessage(input.value));

  input.addEventListener("keydown", (e) => {
    if (e.key === "Enter" && !e.shiftKey) {
      e.preventDefault();
      sendMessage(input.value);
    }
  });

  input.addEventListener("input", () => {
    sendBtn.disabled = !input.value.trim();
    input.style.height = "auto";
    input.style.height = Math.min(input.scrollHeight, 88) + "px";
  });

  premadeBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const raw = btn.textContent!.trim().replace(/^>\s*/, "");
      sendMessage(raw);
    });
  });

  modal.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;
    const skillBtn = target.closest(".skill-info-btn");
    if (skillBtn) {
      const skillType = skillBtn.getAttribute("data-skill");
      const queries: Record<string, string> = {
        "core-languages": "Tell me more about Artem's experience with Python, JavaScript, C++, C#, Java, and PHP.",
        frontend: "Explain Artem's frontend development skills with React, Vue.js, and Next.js.",
        backend: "Detail Artem's backend development experience with Node.js, Django, Flask, and Laravel.",
        database: "What is Artem's experience with PostgreSQL and database design?",
        "data-science": "Tell me about Artem's data science and bioinformatics skills.",
        ai: "Explain Artem's experience with AI integration and machine learning.",
        tools: "What development tools does Artem use?",
        management: "Tell me about Artem's project management experience.",
      };
      const query = queries[skillType || ""];
      if (query) sendMessage(query);
    }
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && !modal.classList.contains("hidden")) closeModal();
  });
</script>