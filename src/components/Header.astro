---
import type { Locale } from "@/i18n";
import { locales, t, localeLabel } from "@/i18n";
import { profile } from "@/data/profile";
import { Icon } from "astro-icon/components";

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const base = profile.base;

const navItems = [
  { labelKey: "nav.home", href: `${base}/${locale}/` },
  { labelKey: "nav.about", href: `${base}/${locale}/#about` },
  { labelKey: "nav.journey", href: `${base}/${locale}/#journey` },
  { labelKey: "nav.skills", href: `${base}/${locale}/#skills` },
  { labelKey: "nav.projects", href: `${base}/${locale}/#projects` },
  { labelKey: "nav.blog", href: `${base}/${locale}/blog/` },
  { labelKey: "nav.contact", href: `${base}/${locale}/#contact` },
];
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div
    class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16"
  >
    <a href={`${base}/${locale}/`} class="text-[var(--color-text-primary)] text-xl font-bold tracking-tight">
      {locale === "uk" ? profile.nameUk : profile.name}
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-8">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="text-sm font-medium transition-colors duration-200"
          class:list={[
            "text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)]",
          ]}
        >
          {t(item.labelKey, locale)}
        </a>
      ))}

      <!-- Language Switcher -->
      <div class="flex items-center gap-1 border-l border-[var(--color-border-light)] pl-4">
        {locales.map((l) => (
          <a
            href={`${base}/${l}/`}
            class="px-2 py-1 text-xs font-mono font-medium rounded transition-colors duration-200"
            class:list={[
              l === locale
                ? "text-[var(--color-text-primary)] bg-[var(--color-bg-tertiary)]"
                : "text-[var(--color-text-tertiary)] hover:text-[var(--color-text-secondary)]",
            ]}
          >
            {localeLabel(l)}
          </a>
        ))}
      </div>

      <!-- Theme Toggle -->
      <button
        id="theme-toggle"
        class="p-2 rounded-lg transition-colors duration-200 cursor-pointer"
        class:list={[
          "text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:bg-[var(--color-bg-tertiary)]",
        ]}
        aria-label={t("aiChat.open", locale)}
      >
        <Icon name="lucide:sun" class="w-5 h-5 hidden dark:block" />
        <Icon name="lucide:moon" class="w-5 h-5 block dark:hidden" />
      </button>
    </nav>

    <!-- Mobile Menu Button -->
    <div class="flex md:hidden items-center gap-3">
      <!-- Language Switcher (mobile) -->
      <div class="flex items-center gap-1">
        {locales.map((l) => (
          <a
            href={`${base}/${l}/`}
            class="px-1.5 py-0.5 text-xs font-mono font-medium rounded transition-colors duration-200"
            class:list={[
              l === locale
                ? "text-[var(--color-text-primary)] bg-[var(--color-bg-tertiary)]"
                : "text-[var(--color-text-tertiary)] hover:text-[var(--color-text-secondary)]",
            ]}
          >
            {localeLabel(l)}
          </a>
        ))}
      </div>
      <button
        id="theme-toggle-mobile"
        class="p-2 rounded-lg transition-colors duration-200 cursor-pointer"
        class:list={[
          "text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:bg-[var(--color-bg-tertiary)]",
        ]}
        aria-label={t("aiChat.open", locale)}
      >
        <Icon name="lucide:sun" class="w-5 h-5 hidden dark:block" />
        <Icon name="lucide:moon" class="w-5 h-5 block dark:hidden" />
      </button>
      <button
        id="mobile-menu-btn"
        class="p-2 rounded-lg transition-colors duration-200 cursor-pointer"
        class:list={[
          "text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:bg-[var(--color-bg-tertiary)]",
        ]}
        aria-label={t("aiChat.open", locale)}
      >
        <Icon name="lucide:menu" class="w-6 h-6" />
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="md:hidden fixed inset-0 z-[55] bg-[var(--color-bg-main)] translate-x-full transition-transform duration-300"
  >
    <div class="flex items-center justify-end h-16 px-4">
      <button
        id="mobile-menu-close"
        class="p-2 rounded-lg cursor-pointer"
        class:list={[
          "text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)]",
        ]}
        aria-label={t("aiChat.close", locale)}
      >
        <Icon name="lucide:x" class="w-6 h-6" />
      </button>
    </div>
    <nav class="flex flex-col items-center gap-6 mt-12">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="text-lg font-medium transition-colors duration-200"
          class:list={[
            "text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)]",
          ]}
        >
          {t(item.labelKey, locale)}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const header = document.getElementById("header")!;

  window.addEventListener("scroll", () => {
    if (window.scrollY > 50) {
      header.style.backgroundColor = "var(--color-bg-main)";
      header.style.borderBottom = "1px solid var(--color-border-light)";
    } else {
      header.style.backgroundColor = "transparent";
      header.style.borderBottom = "none";
    }
  });

  const toggleTheme = (btn?: HTMLElement) => {
    const html = document.documentElement;
    const isDark = html.classList.contains("dark");
    html.classList.toggle("dark", !isDark);
    localStorage.setItem("theme", !isDark ? "dark" : "light");
    if (btn) {
      btn
        .querySelectorAll("svg")
        .forEach((svg) => svg.classList.toggle("hidden"));
    }
  };

  document.getElementById("theme-toggle")?.addEventListener("click", (e) => {
    toggleTheme(e.currentTarget as HTMLElement);
  });
  document
    .getElementById("theme-toggle-mobile")
    ?.addEventListener("click", (e) => {
      toggleTheme(e.currentTarget as HTMLElement);
    });

  // Mobile menu
  const mobileMenu = document.getElementById("mobile-menu")!;
  document.getElementById("mobile-menu-btn")?.addEventListener("click", () => {
    mobileMenu.classList.remove("translate-x-full");
  });
  document
    .getElementById("mobile-menu-close")
    ?.addEventListener("click", () => {
      mobileMenu.classList.add("translate-x-full");
    });
  mobileMenu.querySelectorAll("a").forEach((a) => {
    a.addEventListener("click", () => {
      mobileMenu.classList.add("translate-x-full");
    });
  });
</script>
