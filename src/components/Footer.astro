---
import type { Locale } from "@/i18n";
import { t } from "@/i18n";
import { profile } from "@/data/profile";
import { Icon } from "astro-icon/components";

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<footer
  class="py-8 text-center border-t"
  class:list={[
    "bg-[var(--color-bg-main)] border-[var(--color-border-light)]",
  ]}
>
  <div class="max-w-6xl mx-auto px-4">
    <p class="text-sm text-[var(--color-text-tertiary)] mb-3">
      {t("footer.builtWith", locale).replace("{year}", String(new Date().getFullYear())).replace("{name}", locale === "uk" ? profile.nameUk : profile.name)}
    </p>
    <a
      href={profile.repo}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 text-sm font-medium transition-colors duration-200"
      class:list={[
        "text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)]",
      ]}
    >
      <Icon name="lucide:external-link" class="w-4 h-4" />
      {t("footer.viewSource", locale)}
    </a>
  </div>
</footer>
