---
---

<canvas id="threejs-canvas" class="absolute inset-0 w-full h-full z-0"></canvas>

<script>
  import * as THREE from "three";

  const canvas = document.getElementById("threejs-canvas") as HTMLCanvasElement;
  const hero   = canvas.parentElement as HTMLElement;

  if (canvas && hero) {
    // ─── Mobile detection ─────────────────────────────────────────────────
    const isMobile   = window.matchMedia("(max-width: 639px)").matches;
    const isTouch    = navigator.maxTouchPoints > 0;
    const prefersRed = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    const scene  = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(75, hero.clientWidth / hero.clientHeight, 0.1, 1000);
    camera.position.z = isMobile ? 6 : 5;

    const renderer = new THREE.WebGLRenderer({ canvas, antialias: !isMobile, alpha: true });
    renderer.setSize(hero.clientWidth, hero.clientHeight);
    // Cap pixel ratio at 1.5 on mobile to halve fill-rate
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, isMobile ? 1.5 : 2));

    // ─── Theme helpers ────────────────────────────────────────────────────
    const getIsDark    = () => document.documentElement.classList.contains("dark");
    const getMeshColor = () => getIsDark() ? 0xffffff : 0x000000;
    const getWireColor = () => getIsDark() ? 0x555555 : 0xaaaaaa;

    // ─── Torus knot ───────────────────────────────────────────────────────
    // Lower tessellation on mobile saves geometry processing time
    const knotGeometry = new THREE.TorusKnotGeometry(
      0.8, 0.3,
      isMobile ? 80  : 128,
      isMobile ? 12  : 16
    );
    const knotMaterial = new THREE.MeshPhysicalMaterial({
      color:             new THREE.Color(getMeshColor()),
      emissive:          new THREE.Color(getMeshColor()),
      emissiveIntensity: 0.8,
      metalness:         0.0,
      roughness:         1.0,
      transparent:       true,
      opacity:           0.92,
    });
    const knot = new THREE.Mesh(knotGeometry, knotMaterial);
    scene.add(knot);

    // ─── Wireframe overlay ────────────────────────────────────────────────
    const wireframeMaterial = new THREE.MeshPhysicalMaterial({
      color:       new THREE.Color(getWireColor()),
      wireframe:   true,
      transparent: true,
      opacity:     0.12,
    });
    const wireframe = new THREE.Mesh(knotGeometry.clone(), wireframeMaterial);
    scene.add(wireframe);

    // ─── Particle field ───────────────────────────────────────────────────
    // Half particle count on mobile
    const particleCount = isMobile ? 600 : 1500;
    const positions     = new Float32Array(particleCount * 3);
    const particleColors = new Float32Array(particleCount * 3);

    const buildParticleColors = () => {
      const isDark = getIsDark();
      const c1 = new THREE.Color(isDark ? 0x888888 : 0x777777);
      const c2 = new THREE.Color(isDark ? 0xffffff : 0x000000);
      for (let i = 0; i < particleCount; i++) {
        const mixed = new THREE.Color().lerpColors(c1, c2, Math.random());
        particleColors[i * 3]     = mixed.r;
        particleColors[i * 3 + 1] = mixed.g;
        particleColors[i * 3 + 2] = mixed.b;
      }
    };

    for (let i = 0; i < particleCount; i++) {
      const radius = 2 + Math.random() * 4;
      const theta  = Math.random() * Math.PI * 2;
      const phi    = Math.acos(2 * Math.random() - 1);
      positions[i * 3]     = radius * Math.sin(phi) * Math.cos(theta);
      positions[i * 3 + 1] = radius * Math.sin(phi) * Math.sin(theta);
      positions[i * 3 + 2] = radius * Math.cos(phi);
    }
    buildParticleColors();

    const particleGeometry = new THREE.BufferGeometry();
    particleGeometry.setAttribute("position", new THREE.BufferAttribute(positions, 3));
    const colorAttr = new THREE.BufferAttribute(particleColors, 3);
    particleGeometry.setAttribute("color", colorAttr);

    const particleMaterial = new THREE.PointsMaterial({
      size:         isMobile ? 0.07 : 0.06,
      vertexColors: true,
      transparent:  true,
      opacity:      0.7,
      blending:     THREE.NormalBlending,
      depthWrite:   false,
    });
    const particles = new THREE.Points(particleGeometry, particleMaterial);
    scene.add(particles);

    // ─── Theme change observer ────────────────────────────────────────────
    const themeObserver = new MutationObserver(() => {
      const hex = getMeshColor();
      knotMaterial.color.setHex(hex);
      knotMaterial.emissive.setHex(hex);
      wireframeMaterial.color.setHex(getWireColor());
      buildParticleColors();
      colorAttr.needsUpdate = true;
    });
    themeObserver.observe(document.documentElement, { attributes: true, attributeFilter: ["class"] });

    // ─── Input tracking ───────────────────────────────────────────────────
    let mouseX = 0, mouseY = 0;
    let targetKnotRotX = 0, targetKnotRotY = 0;

    // Desktop: mouse parallax
    document.addEventListener("mousemove", (e) => {
      mouseX = (e.clientX - window.innerWidth  / 2) * 0.001;
      mouseY = (e.clientY - window.innerHeight / 2) * 0.001;
    });

    // Mobile: gyroscope parallax (gracefully degraded)
    if (isTouch && typeof DeviceOrientationEvent !== "undefined") {
      const handleOrientation = (e: DeviceOrientationEvent) => {
        if (e.beta  !== null) mouseY = (e.beta  - 45) *  0.004;
        if (e.gamma !== null) mouseX =  e.gamma        *  0.004;
      };

      // iOS 13+ requires permission
      if (typeof (DeviceOrientationEvent as any).requestPermission === "function") {
        // We request lazily on first touch so we're not blocked before gesture
        const requestGyro = async () => {
          const perm = await (DeviceOrientationEvent as any).requestPermission();
          if (perm === "granted") window.addEventListener("deviceorientation", handleOrientation);
          document.removeEventListener("touchstart", requestGyro);
        };
        document.addEventListener("touchstart", requestGyro, { once: true });
      } else {
        window.addEventListener("deviceorientation", handleOrientation);
      }
    }

    let scrollY = 0;
    window.addEventListener("scroll", () => { scrollY = window.scrollY / window.innerHeight; }, { passive: true });

    window.addEventListener("resize", () => {
      if (!hero) return;
      camera.aspect = hero.clientWidth / hero.clientHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(hero.clientWidth, hero.clientHeight);
    });

    // ─── Animation loop ───────────────────────────────────────────────────
    // Slow everything down if reduced-motion is preferred
    const speedScale = prefersRed ? 0.15 : 1;

    const animate = () => {
      requestAnimationFrame(animate);

      const scrollFactor = Math.min(scrollY * 0.5, 1);
      const opacity = Math.max(1 - scrollFactor * 2, 0);
      knotMaterial.opacity      = opacity * 0.92;
      wireframeMaterial.opacity = opacity * 0.12;
      particleMaterial.opacity  = opacity * 0.7;

      targetKnotRotX += (mouseY * 0.5 - targetKnotRotX) * 0.05;
      targetKnotRotY += (mouseX * 0.5 - targetKnotRotY) * 0.05;

      knot.rotation.x     += (0.005 + targetKnotRotX * 0.01) * speedScale;
      knot.rotation.y     += (0.008 + targetKnotRotY * 0.01) * speedScale;
      wireframe.rotation.x = knot.rotation.x;
      wireframe.rotation.y = knot.rotation.y;

      particles.rotation.x += 0.0003 * speedScale;
      particles.rotation.y += 0.0005 * speedScale;

      // On mobile, skip camera parallax to reduce jitter from gyro noise
      if (!isMobile) {
        camera.position.x += (mouseX  * 0.3 - camera.position.x) * 0.03;
        camera.position.y += (-mouseY * 0.3 - camera.position.y) * 0.03;
      }
      camera.lookAt(scene.position);

      renderer.render(scene, camera);
    };

    animate();
  }
</script>
