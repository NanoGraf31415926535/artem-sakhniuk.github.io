<canvas id="threejs-canvas" class="absolute inset-0 w-full h-full z-0"></canvas>

<script>
  import * as THREE from "three";

  const canvas = document.getElementById(
    "threejs-canvas"
  ) as HTMLCanvasElement;
  const hero = canvas.parentElement as HTMLElement;

  if (canvas && hero) {
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(
      75,
      hero.clientWidth / hero.clientHeight,
      0.1,
      1000
    );
    camera.position.z = 5;

    const renderer = new THREE.WebGLRenderer({
      canvas,
      antialias: true,
      alpha: true,
    });
    renderer.setSize(hero.clientWidth, hero.clientHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    // Torus Knot
    const knotGeometry = new THREE.TorusKnotGeometry(0.8, 0.3, 128, 16);
    const knotMaterial = new THREE.MeshPhysicalMaterial({
      color: new THREE.Color(0x6366f1),
      emissive: new THREE.Color(0x4f46e5),
      emissiveIntensity: 0.3,
      metalness: 0.3,
      roughness: 0.4,
      transparent: true,
      opacity: 0.9,
      wireframe: false,
    });
    const knot = new THREE.Mesh(knotGeometry, knotMaterial);
    scene.add(knot);

    // Wireframe overlay
    const wireframeMaterial = new THREE.MeshPhysicalMaterial({
      color: new THREE.Color(0x818cf8),
      wireframe: true,
      transparent: true,
      opacity: 0.15,
    });
    const wireframe = new THREE.Mesh(knotGeometry.clone(), wireframeMaterial);
    scene.add(wireframe);

    // Particle field
    const particleCount = 1500;
    const positions = new Float32Array(particleCount * 3);
    const colors = new Float32Array(particleCount * 3);
    const sizes = new Float32Array(particleCount);

    const color1 = new THREE.Color(0x6366f1);
    const color2 = new THREE.Color(0xec4899);

    for (let i = 0; i < particleCount; i++) {
      const radius = 2 + Math.random() * 4;
      const theta = Math.random() * Math.PI * 2;
      const phi = Math.acos(2 * Math.random() - 1);

      positions[i * 3] = radius * Math.sin(phi) * Math.cos(theta);
      positions[i * 3 + 1] = radius * Math.sin(phi) * Math.sin(theta);
      positions[i * 3 + 2] = radius * Math.cos(phi);

      const mixedColor = new THREE.Color().lerpColors(
        color1,
        color2,
        Math.random()
      );
      colors[i * 3] = mixedColor.r;
      colors[i * 3 + 1] = mixedColor.g;
      colors[i * 3 + 2] = mixedColor.b;

      sizes[i] = Math.random() * 0.08 + 0.02;
    }

    const particleGeometry = new THREE.BufferGeometry();
    particleGeometry.setAttribute(
      "position",
      new THREE.BufferAttribute(positions, 3)
    );
    particleGeometry.setAttribute(
      "color",
      new THREE.BufferAttribute(colors, 3)
    );
    particleGeometry.setAttribute(
      "size",
      new THREE.BufferAttribute(sizes, 1)
    );

    const particleMaterial = new THREE.PointsMaterial({
      size: 0.05,
      vertexColors: true,
      transparent: true,
      opacity: 0.6,
      blending: THREE.AdditiveBlending,
      depthWrite: false,
    });

    const particles = new THREE.Points(particleGeometry, particleMaterial);
    scene.add(particles);

    // Mouse tracking
    let mouseX = 0;
    let mouseY = 0;
    let targetKnotRotX = 0;
    let targetKnotRotY = 0;

    document.addEventListener("mousemove", (event) => {
      mouseX = (event.clientX - window.innerWidth / 2) * 0.001;
      mouseY = (event.clientY - window.innerHeight / 2) * 0.001;
    });

    // Scroll tracking
    let scrollY = 0;
    window.addEventListener("scroll", () => {
      scrollY = window.scrollY / window.innerHeight;
    });

    // Resize
    const onResize = () => {
      if (!hero) return;
      camera.aspect = hero.clientWidth / hero.clientHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(hero.clientWidth, hero.clientHeight);
    };
    window.addEventListener("resize", onResize);

    // Animation loop
    const animate = () => {
      requestAnimationFrame(animate);

      const scrollFactor = Math.min(scrollY * 0.5, 1);

      // Fade out on scroll
      const opacity = Math.max(1 - scrollFactor * 2, 0);
      knot.material.opacity = opacity * 0.9;
      wireframe.material.opacity = opacity * 0.15;
      particleMaterial.opacity = opacity * 0.6;

      // Smooth rotation
      targetKnotRotX += (mouseY * 0.5 - targetKnotRotX) * 0.05;
      targetKnotRotY += (mouseX * 0.5 - targetKnotRotY) * 0.05;

      knot.rotation.x += 0.005 + targetKnotRotX * 0.01;
      knot.rotation.y += 0.008 + targetKnotRotY * 0.01;
      wireframe.rotation.x = knot.rotation.x;
      wireframe.rotation.y = knot.rotation.y;

      // Color shift
      const hue = (Date.now() * 0.0001) % 1;
      const color = new THREE.Color().setHSL(0.7 + Math.sin(hue * Math.PI) * 0.1, 0.6, 0.5);
      knot.material.color.set(color);
      knot.material.emissive.set(color);

      particles.rotation.x += 0.0003;
      particles.rotation.y += 0.0005;

      camera.position.x += (mouseX * 0.3 - camera.position.x) * 0.03;
      camera.position.y += (-mouseY * 0.3 - camera.position.y) * 0.03;
      camera.lookAt(scene.position);

      renderer.render(scene, camera);
    };

    animate();
  }
</script>
