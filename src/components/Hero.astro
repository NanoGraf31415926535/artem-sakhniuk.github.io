---
import Hero3D from "./Hero3D.astro";
import { profile } from "@/data/profile";
---

<section
  id="home"
  class="relative min-h-screen flex items-center justify-center overflow-hidden bg-[var(--color-bg-main)]"
>
  <Hero3D />

  <div class="absolute inset-0 bg-gradient-to-b from-[var(--color-bg-main)]/60 via-transparent to-[var(--color-bg-main)]/80 z-[1]"></div>

  <div class="relative z-10 text-center max-w-3xl mx-auto px-4">
    <h1 class="gradient-text text-5xl sm:text-6xl md:text-7xl font-extrabold mb-6 leading-tight drop-shadow-lg">
      {profile.name}
    </h1>
    <p class="text-xl sm:text-2xl text-[var(--color-text-light)] mb-4 font-light drop-shadow-md">
      {profile.title} based in {profile.location}
    </p>
    <p class="text-base sm:text-lg text-slate-200 max-w-xl mx-auto mb-8 leading-relaxed drop-shadow-md">
      {profile.summary}
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <a
        href="#about"
        class="gradient-bg text-white px-8 py-3 rounded-full font-semibold transition-all duration-300 hover:scale-105 hover:shadow-lg active:scale-95"
      >
        Discover My Journey
      </a>
      <button
        id="open-ai-chat-btn"
        class="px-8 py-3 rounded-full font-semibold border-2 backdrop-blur-sm transition-all duration-300 cursor-pointer"
        class:list={[
          "border-[var(--color-primary)] text-[var(--color-primary)] hover:gradient-bg hover:text-white hover:border-transparent",
        ]}
      >
        Ask Artem AI
      </button>
      <a
        href={profile.cvPath}
        download="Artem_Sakhniuk_CV.pdf"
        class="px-8 py-3 rounded-full font-semibold border-2 backdrop-blur-sm transition-all duration-300"
        class:list={[
          "border-white/30 text-white/90 hover:border-white hover:text-white hover:bg-white/10",
        ]}
      >
        Download CV
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 animate-bounce">
    <svg
      class="w-6 h-6 text-white/50"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M19 14l-7 7m0 0l-7-7m7 7V3"
      />
    </svg>
  </div>
</section>
