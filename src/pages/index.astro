---
import { profile } from "@/data/profile";
const base = profile.base;
const redirectUrl = base + "/en/";
---

<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{profile.name} - {profile.title.en}</title>
  <meta http-equiv="refresh" content={"0; url=" + redirectUrl} />
  <meta name="base-path" content={base} />
</head>
<body>
  <p>Redirecting to <a href={redirectUrl}>{profile.name}</a>...</p>
  <script>
    (function() {
      var base = document.querySelector('meta[name="base-path"]')?.getAttribute("content") || "";
      var lang = (navigator.language || "en").substring(0, 2);
      var supported = ["en", "uk", "de"];
      if (supported.indexOf(lang) === -1) lang = "en";
      window.location.replace(base + "/" + lang + "/");
    })();
  </script>
</body>
</html>
