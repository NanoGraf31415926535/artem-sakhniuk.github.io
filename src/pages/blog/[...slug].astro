---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { Icon } from "astro-icon/components";
import { getCollection, type CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts
    .filter((post: CollectionEntry<"blog">) => !post.data.draft || import.meta.env.DEV)
    .map((post: CollectionEntry<"blog">) => ({
      params: { slug: post.slug },
      props: { post },
    }));
}

type Props = {
  post: CollectionEntry<"blog">;
};

const { post } = Astro.props as Props;
const { Content } = await post.render();
---

<BaseLayout
  title={`${post.data.title} - Blog`}
  description={post.data.description || post.data.title}
>
  <Header />

  <main class="min-h-screen pt-24 pb-16">
    <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-8">
        <a
          href="/artem-sakhniuk.github.io/blog/"
          class="inline-flex items-center gap-1.5 text-sm transition-colors duration-200"
          class:list={[
            "text-[var(--color-text-tertiary)] hover:text-[var(--color-text-primary)]",
          ]}
        >
          <Icon name="lucide:arrow-left" class="w-4 h-4" />
          Back to blog
        </a>
      </div>

      <header class="mb-8">
        <h1 class="text-3xl sm:text-4xl font-bold mb-3">
          {post.data.title}
        </h1>

        <div class="flex items-center gap-2 text-sm text-[var(--color-text-tertiary)]">
          <Icon name="lucide:calendar" class="w-4 h-4" />
          <time datetime={post.data.publishedDate.toISOString()}>
            {post.data.publishedDate.toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })}
          </time>
        </div>

        {post.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-4">
            {post.data.tags.map((tag: string) => (
              <span
                class="px-2.5 py-0.5 text-xs font-medium rounded-full"
                class:list={[
                  "bg-[var(--color-bg-tertiary)] text-[var(--color-text-secondary)]",
                ]}
              >
                {tag}
              </span>
            ))}
          </div>
        )}
      </header>

      <div class="blog-content max-w-none">
        <Content />
      </div>
    </article>
  </main>

  <Footer />
</BaseLayout>
